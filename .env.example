# AIE 环境配置

# ===================
# 应用配置
# ===================
AIE_APP_NAME=AIE
AIE_VERSION=1.0.0

# 端口配置
AIE_API_PORT=21000
AIE_WS_PORT=20000
AIE_WEB_PORT=22000

# 路径配置 (使用环境变量覆盖默认值)
# AIE_DATA_DIR=/path/to/data
# AIE_WORKSPACE_DIR=/path/to/workspace
# AIE_CONFIG_DIR=/path/to/config
# AIE_MEMORY_DIR=/path/to/memory
# AIE_SKILLS_DIR=/path/to/skills

# 数据库配置
# AIE_DB_URL=sqlite:///data/aie.db
# 或使用 PostgreSQL
# AIE_DB_URL=postgresql://user:pass@localhost/aie

# 日志配置
AIE_LOG_LEVEL=INFO

# 开发模式
AIE_DEBUG=false

# ===================
# API Keys (必填)
# ===================

# OpenAI
OPENAI_API_KEY=

# Qwen / 通义千问 (DashScope)
DASHSCOPE_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# ===================
# 邮件配置
# ===================

SMTP_SERVER=smtp.163.com
SMTP_PORT=465
SENDER_EMAIL=your_email@163.com
SENDER_PASSWORD=your_smtp_auth_code
RECEIVER_EMAIL=recipient@example.com
