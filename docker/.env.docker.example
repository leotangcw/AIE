# AIE Docker 环境变量配置示例
# 复制此文件为 .env.docker 并修改相应配置

# ===========================================
# 网络配置
# ===========================================
# 后端 API 端口
API_PORT=8000

# 前端端口 (开发环境)
FRONTEND_PORT=3000

# 数据库端口
POSTGRES_PORT=5432

# Redis 端口
REDIS_PORT=6379

# ===========================================
# 数据库配置
# ===========================================
POSTGRES_DB=aie
POSTGRES_USER=aie
POSTGRES_PASSWORD=aie_password

# 数据库连接 URL (Docker 内部)
DATABASE_URL=postgresql+asyncpg://aie:aie_password@postgres:5432/aie

# ===========================================
# Redis 配置
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# 应用配置
# ===========================================
# 环境：development, production, ci
APP_ENV=development

# 调试模式
DEBUG=false

# 密钥 (生产环境务必修改)
SECRET_KEY=your-secret-key-change-in-production

# ===========================================
# LLM 配置
# ===========================================
# LLM 提供商：litellm, openai, anthropic, etc.
LLM_PROVIDER=litellm

# 模型名称
LLM_MODEL=claude-sonnet-4-6

# API 密钥
API_KEY=your-api-key-here

# ===========================================
# API 配置
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000

# ===========================================
# 前端配置
# ===========================================
# 开发环境 API 地址
VITE_API_BASE_URL=http://localhost:8000

# WebSocket 地址
VITE_WS_URL=ws://localhost:8000/ws/chat

# ===========================================
# Docker 配置
# ===========================================
# Docker 网络名称
DOCKER_NETWORK=aie-network

# ===========================================
# 日志配置
# ===========================================
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=/app/logs/aie.log
